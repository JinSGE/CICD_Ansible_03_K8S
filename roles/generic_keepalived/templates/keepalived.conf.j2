global_defs {
  router_id {{ keepalived_router_id | default(inventory_hostname) }}
}

{% if keepalived_check_process is defined %}
vrrp_script chk_{{ keepalived_check_process }} {
  script "pidof {{ keepalived_check_process }}"
  interval 1
  weight -20
}
{% endif %}

vrrp_instance {{ vrrp.name }} {
  state {{ vrrp.state | default('BACKUP') }}
  interface {{ vrrp.interface }}
  virtual_router_id {{ vrrp.vrid }}
  priority {{ vrrp.priority }}
  advert_int {{ vrrp.advert_int | default(1) }}

  authentication {
    auth_type PASS
    auth_pass {{ vrrp.auth_pass }}
  }

  virtual_ipaddress {
    {{ vrrp.vip }}
  }

{% if keepalived_check_process is defined %}
  track_script {
    chk_{{ keepalived_check_process }}
  }
{% endif %}
}
