pipeline {
    agent any
    
    // ✅ 파라미터 추가: 배포할 태그를 직접 입력받음 (기본값: latest)
    parameters {
        string(name: 'IMAGE_TAG', defaultValue: 'latest', description: '배포할 Harbor 이미지 태그를 입력하세요 (예: latest, 1, v1.0)')
    }
    
    environment {
        // GITEA_HOST = '10.2.2.70:3001'
        GITEA_HOST = '10.2.2.40:3001'
        REPO_NAME = '03_K8s_Infra'
    }
    
    stages {
        // [1단계: 빌드] 복구됨
        stage('Build & Push') {
            steps {
                script {
                    echo "🐳 Docker Image Build & Push..."
                    def harborHost = "10.2.2.40:5000"
                    def imageName = "library/kma-api"
                    def tag = params.IMAGE_TAG
                    
                    // Login to Harbor
                    sh "docker login ${harborHost} -u admin -p Admin123"
                    
                    // Build Image
                    dir('apps/kma-api') {
                        sh "docker build -t ${harborHost}/${imageName}:${tag} ."
                    }
                    
                    // Push Image
                    sh "docker push ${harborHost}/${imageName}:${tag}"
                    
                    // Cleanup local image
                    sh "docker rmi ${harborHost}/${imageName}:${tag}"
                }
            }
        } 
        
        // [2단계] Helm Chart 버전 업데이트 (이것만 실행)
        stage('Update Helm Chart') {
            steps {
                echo "☸️ kma-api 배포 시작: Harbor 태그(${params.IMAGE_TAG}) 적용"
                
                sh """
                    set -e
                    
                    # 1. 작업 공간 준비
                    rm -rf /tmp/gitops_kma && mkdir -p /tmp/gitops_kma
                    cd /tmp/gitops_kma
                    
                    # 2. 03_K8s_Infra 저장소 가져오기
                    git clone http://jenkins:JenkinsPass123@${GITEA_HOST}/admin/${REPO_NAME}.git .
                    
                    git config user.email "jenkins@antigravity.local"
                    git config user.name "Jenkins CI"
                    
                    # 3. values.yaml 수정 (입력받은 태그로 변경)
                    sed -i "s/tag: .*/tag: \\"${params.IMAGE_TAG}\\"/" apps/kma-api/helm/values.yaml
                    
                    # 4. 변경사항 확인
                    echo "🔍 변경된 태그 확인:"
                    grep "tag:" apps/kma-api/helm/values.yaml
                    
                    git add apps/kma-api/helm/values.yaml
                    
                    # 변경된 내용이 있을 때만 Git에 올림
                    if ! git diff-index --quiet HEAD; then
                        git commit -m "Deploy kma-api image tag: ${params.IMAGE_TAG}"
                        git push http://jenkins:JenkinsPass123@${GITEA_HOST}/admin/${REPO_NAME}.git main
                        echo "✅ Helm Chart 업데이트 완료! ArgoCD가 곧 배포합니다."
                    else
                        echo "⚠️ 변경 사항 없음 (이미 해당 태그로 설정되어 있습니다)"
                    fi
                    
                    # 5. 정리
                    rm -rf /tmp/gitops_kma
                """
            }
        }
    }
}